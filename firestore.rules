rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default rule: Deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to access their own data
    // Assumes users have their data nested under a `users/{userId}` collection
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Explicitly allow users to read and write their own user profile document
    match /users/{userId} {
      // Allow reading user profiles for the leaderboard
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
